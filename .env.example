# Supabase (auth + base de datos)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Origen público de la app (producción). Usado en emails de recuperación de contraseña.
# Ej: https://crm.tudominio.com
NEXT_PUBLIC_APP_PUBLIC_ORIGIN=
# En Supabase Dashboard → Authentication → URL Configuration:
#   Site URL: tu dominio de producción
#   Redirect URLs: http://localhost:3000/clientes/restablecer-contrasena
#                  https://crm.tudominio.com/clientes/restablecer-contrasena
# Opcional: solo en servidor para operaciones admin
SUPABASE_SERVICE_ROLE_KEY=

# N8N — webhook WhatsApp (envío de mensajes y media)
NEXT_PUBLIC_N8N_WHATSAPP_WEBHOOK_URL=
# Alias opcional (compatibilidad)
NEXT_PUBLIC_N8N_WEBHOOK_URL=

# OpenAI — análisis IA de conversaciones
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
